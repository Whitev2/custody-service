# ---- Custody Service configuration (example) ----
# Copy to .env and fill in your own values. NEVER commit a real .env.

# Runtime
LOG_LEVEL=INFO
STAND=local                       # local | dev | prod (local reads from env, dev/prod from Vault)
DEFAULT_PROVIDER=fireblocks
BACKEND_URL=http://localhost:8000

# Fireblocks (provide your own — do not commit)
API_KEY=your-fireblocks-api-key
FIREBLOCKS_SANDBOX=true
PRIVATE_KEY_FILE=secrets/fireblocks.key   # path to YOUR Fireblocks secret key (gitignored)
# PRIVATE_KEY=                    # alternatively, the key contents via env (escaped newlines)

# PostgreSQL (local mode)
CUSTODY_DB_HOST=localhost
CUSTODY_DB_PORT=5432
CUSTODY_DB_USER=postgres
CUSTODY_DB_PASSWORD=changeme
CUSTODY_DB_NAME=pg_custody

# RabbitMQ
RABBIT_HOST=localhost
RABBIT_PORT=5672
RABBIT_USER=guest
RABBIT_PASSWORD=changeme
RABBITMQ_EXCHANGE=custody_events

# Redis (optional)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# HashiCorp Vault (used when STAND=dev|prod)
VAULT_ADDR=https://vault.example.internal:8200
VAULT_TOKEN=your-vault-token
VAULT_KV_MOUNT=kv
VAULT_SECRET_BASE=app
VAULT_AUTH_MOUNT=kubernetes
VAULT_ROLE=custody
VAULT_ROLE_PREFIX=custody
VAULT_MIGRATE_ROLE=custody-migrator
